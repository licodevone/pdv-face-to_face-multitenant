{
  "name": "pdv-face-delivery",
  "version": "0.1.0",
  "description": "Sistema de PDV Face Delivery Multitenant para gerenciamento de vendas.",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "electron-starter.cjs",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:backend": "tsx watch src/server.ts",
    "dev:frontend": "next dev frontend --webpack",
    "dev:desktop": "tsx scripts/dev-desktop.ts",
    "build": "pnpm build:backend && pnpm build:frontend && pnpm build:desktop",
    "build:backend": "tsup src/server.ts --format esm --target es2024 --sourcemap --clean",
    "build:frontend": "NODE_ENV=production next build frontend",
    "build:desktop": "tsc -p desktop/tsconfig.json",
    "start:frontend": "next start frontend",
    "eslint": "eslint .",
    "typecheck": "tsc -p tsconfig.json && tsc -p frontend/tsconfig.json --noEmit && tsc -p desktop/tsconfig.json --noEmit",
    "prisma": "prisma",
    "studio": "prisma studio --port 5555 --browser none",
    "data": "tsx src/scripts/list-data.ts",
    "db:backup": "bash ../scripts/backup-db.sh",
    "db:format": "prisma --config prisma.config.ts format",
    "db:generate": "prisma --config prisma.config.ts generate",
    "db:migrate": "prisma --config prisma.config.ts migrate dev",
    "db:reset": "prisma migrate reset --config prisma.config.ts",
    "db:migrate:prod": "prisma --config prisma.config.ts migrate deploy",
    "db:studio": "prisma --config prisma.config.ts studio",
    "db:seed": "tsx prisma/seed.ts",
    "version:list": "git --no-pager tag --sort=-creatordate",
    "version:rollback": "bash ../scripts/rollback-version.sh",
    "version:snapshot": "bash ../scripts/create-version.sh",
    "postinstall": "prisma generate",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:math": "vitest run tests/unit/math.test.ts",
    "start": "electron-forge start",
    "package": "electron-forge package -c forge.config.cjs",
    "make": "electron-forge make -c forge.config.cjs",
    "make:linux": "electron-forge make --platform=linux --arch=x64 -c forge.config.cjs",
    "make:win": "electron-forge make --platform=win32 --arch=x64 -c forge.config.cjs"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/adapter-pg": "7.4.0",
    "@prisma/client": "7.4.0",
    "@scalar/fastify-api-reference": "1.44.20",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "better-auth": "1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "decimal.js": "^10.6.0",
    "dotenv": "17.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "fastify": "5.7.4",
    "fastify-type-provider-zod": "6.1.0",
    "lucide-react": "^1.17.0",
    "next": "^16.1.1",
    "pg": "^8.10.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/decimal.js": "^7.4.3",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/ui": "^4.1.8",
    "electron": "^26.0.0",
    "eslint": "^9.39.1",
    "playwright": "^1.60.0",
    "playwright-core": "^1.60.0",
    "prisma": "^7.8.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
