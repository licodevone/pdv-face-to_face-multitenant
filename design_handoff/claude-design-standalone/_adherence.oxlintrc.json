{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/catalog/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/pdv/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warn|danger|neutral)$/]",
        "message": "<Badge> tone must be one of 'success' | 'warn' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|icon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:soft|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: soft."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|count|icon|active|key|ref|className|style|children)$/]",
        "message": "<CategoryChip> doesn't accept that prop. Declared props: label, count, icon, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|note|tone|key|ref|className|style|children)$/]",
        "message": "<MetricTile> doesn't accept that prop. Declared props: label, value, note, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|success|accent)$/]",
        "message": "<MetricTile> tone must be one of 'neutral' | 'success' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|priceInCents|imageUrl|stockStatus|unit|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, priceInCents, imageUrl, stockStatus, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='stockStatus'] > Literal[value!=/^(?:AVAILABLE|LOW_STOCK|OUT_OF_STOCK)$/]",
        "message": "<ProductCard> stockStatus must be one of 'AVAILABLE' | 'LOW_STOCK' | 'OUT_OF_STOCK'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='unit'] > Literal[value!=/^(?:UNIT|KG)$/]",
        "message": "<ProductCard> unit must be one of 'UNIT' | 'KG'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
